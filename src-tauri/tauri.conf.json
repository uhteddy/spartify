{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "spartify",
  "version": "0.1.0",
  "identifier": "com.uhteddy.spartify",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Spartify",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["spartify"]
      }
    },
    "shell": {
      "open": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCODk2QUMzNkE0N0I3QzUKUldURnQwZHF3MnFKTzl4aHhETzN5TFVTUS80aGFhaUV1QUNyYWN6Z1YxcVYrR1JVanpqREtwa3IK",
      "endpoints": [
        "https://github.com/uhteddy/spartify/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/bore"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
