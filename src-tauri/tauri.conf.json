{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spartify",
  "version": "0.5.0",
  "identifier": "com.uhteddy.spartify",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Spartify",
        "width": 1000,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["spartify"]
      }
    },
    "shell": {
      "open": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM0OUJERjM4OTMzNTI2RjEKUldUeEpqV1RPTitieE1wOXZvVEszVWxvelJ5TC9YV0tNTVgrWHJlUThGVXkrU09JOUZua0JEM1gK",
      "endpoints": [
        "https://github.com/uhteddy/spartify/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/frpc"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
